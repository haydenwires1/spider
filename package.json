{
  "name": "website-audit-crawler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,green \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "build": "npm run build -w packages/audit-core && npm run build -w apps/api && npm run build -w apps/web",
    "start": "node apps/api/dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "playwright:install": "playwright install chromium"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  }
}
